pipeline {
  agent {label 'ns17-kube'}  ##chnage

  stages {

    stage('Checkout') {
      steps {
        git branch: 'main',
                    credentialsId: 'ns17-github-cred',  ##chnage
                    url: 'git@github.com:pgaws/k8slab.git'           ## ur git repo          
      }
    }
    stage('Check on Kubernetes') {
      steps {
        sh '''
          export KUBECONFIG=$HOME/k8s-3-node.conf
          kubectl get pods
          kubectl get svc
          kubectl get deployments
        '''
      }
    }
    stage('Deployment on Kubernetes') {
      steps {
        sh '''
          export KUBECONFIG=$HOME/k8s-3-node.conf
          kubectl apply -f .
        '''
      }
    }

 

  }
}
