pipeline {
agent any

```
environment {
    RELEASE_NAME = "python-app"
    CHART_PATH = "./helm-py-redis"
    NAMESPACE = "sri-27"
    KUBECONFIG = "/home/labuser/k8s-3-node.conf"

    IMAGE_NAME = "bittu818/python-app"
    IMAGE_TAG = "v1"
}

stages {

    stage('Clone Repository') {
        steps {
            git branch: 'main',
            credentialsId: 'sri-27-github-cred',
            url: 'git@github.com:bittu818/myk8slab.git'
        }
    }

    stage('Verify Cluster Access') {
        steps {
            sh '''
            export KUBECONFIG=${KUBECONFIG}

            kubectl get nodes
            kubectl get ns
            '''
        }
    }

    stage('Helm Lint') {
        steps {
            sh '''
            helm lint ${CHART_PATH}
            '''
        }
    }

    stage('Docker Login') {
        steps {
            withCredentials([usernamePassword(
                credentialsId: 'sri-27-doc-cred',
                usernameVariable: 'DOCKER_USER',
                passwordVariable: 'DOCKER_PASS'
            )]) {

                sh '''
                docker login -u $DOCKER_USER -p $DOCKER_PASS
                '''
            }
        }
    }

    stage('Build Docker Image') {
        steps {
            sh '''
            docker build -t ${IMAGE_NAME}:${IMAGE_TAG} .
            '''
        }
    }

    stage('Push Docker Image') {
        steps {
            sh '''
            docker push ${IMAGE_NAME}:${IMAGE_TAG}
            '''
        }
    }

    stage('Deploy Application') {
        steps {
            sh '''
            export KUBECONFIG=${KUBECONFIG}

            helm upgrade --install ${RELEASE_NAME} ${CHART_PATH} \
            --namespace ${NAMESPACE}
            '''
        }
    }

    stage('Verify Deployment') {
        steps {
            sh '''
            export KUBECONFIG=${KUBECONFIG}

            kubectl get pods -n ${NAMESPACE}
            kubectl get svc -n ${NAMESPACE}
            helm list -n ${NAMESPACE}
            '''
        }
    }
}

post {

    success {
        echo 'Application deployed successfully!'
    }

    failure {
        echo 'Pipeline failed!'
    }
}
```

